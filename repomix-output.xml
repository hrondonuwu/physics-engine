# Handles numerical integration of equations of motion
from engine.config import DT

def semi_implicit_euler(objects):
    """
    Applies Semi-Implicit Euler integration to a list of objects.
    Updates velocities based on accumulated forces, then updates positions.
    """
    for obj in objects:
        if obj.mass <= 0:
            continue # Avoid division by zero, or handle immovable objects

        # Update velocity: v(t+dt) = v(t) + (F/m) * dt
        for i in range(len(obj.velocity)):
            acceleration = obj.force_accumulator[i] / obj.mass
            obj.velocity[i] += acceleration * DT

        # Update position: x(t+dt) = x(t) + v(t+dt) * dt
        for i in range(len(obj.position)):
            obj.position[i] += obj.velocity[i] * DT

        # Clear forces for the next timestep
        obj.clear_forces()
