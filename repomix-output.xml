# Manages the timestep loop, applies forces, and integrates
from engine.config import DT
from engine.integrator import semi_implicit_euler

class World:
    def __init__(self):
        """
        Initializes the physics world with empty lists for simulation components.
        """
        self.objects = []
        self.forces = []
        self.collision_handlers = []
        self.sensors = []
        self.active_events = [] # For things like temporary pushes
        self.step_count = 0
        self.time = 0.0

    def add_object(self, obj):
        if obj not in self.objects:
            self.objects.append(obj)

    def add_force(self, force):
        # Separate collisions from continuous forces
        if type(force).__name__ == "Collisions":
            self.collision_handlers.append(force)
        else:
            self.forces.append(force)

    def add_sensor(self, sensor):
        self.sensors.append(sensor)

    def step(self):
        """
        Advances the simulation by one timestep (DT).
        """
        self.step_count += 1
        self.time = self.step_count * DT
        
        # Store old positions for raycasting
        old_positions = {id(obj): list(obj.position) for obj in self.objects}

        # 1. Apply global continuous forces (e.g., gravity)
        for force in self.forces:
            force.apply(self.objects)
            
        # 2. Apply active experiment events (e.g., ongoing pushes)
        events_to_keep = []
        for event in self.active_events:
            event["object"].apply_force(event["force_vector"])
            event["remaining_time"] -= DT
            if event["remaining_time"] > 0:
                events_to_keep.append(event)
        self.active_events = events_to_keep

        # 3. Integrate to update velocities and positions
        semi_implicit_euler(self.objects)
        
        # 4. Handle collisions after movement using old positions
        for handler in self.collision_handlers:
            handler.apply(self.objects, old_positions)

        # 5. Update sensor internal timers
        for sensor in self.sensors:
            if hasattr(sensor, "tick"):
                sensor.tick()

    def run(self, duration):
        """
        Runs the simulation loop for a specified duration in seconds.
        """
        steps = int(duration / DT)
        for _ in range(steps):
            self.step()
