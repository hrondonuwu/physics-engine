import random

class PushExperiment:
    # Map qualitative strengths to approximate force magnitudes
    STRENGTH_MAP = {
        "soft": 1.0,
        "medium": 5.0,
        "hard": 10.0,
        "very_hard": 20.0
    }

    def __init__(self, world, force_noise_std=0.5, pos_noise_std=1e-3, vel_noise_std=1e-3):
        """
        Initializes the push experiment within a specific world.
        """
        self.world = world
        self.force_noise_std = force_noise_std
        self.pos_noise_std = pos_noise_std
        self.vel_noise_std = vel_noise_std
        self.active_pushes = [] # Track pushes currently happening

    def apply(self, obj, direction, strength="medium", duration=1.0):
        """
        Initiates a push on an object with experimental imperfection.
        Accepts only qualitative strengths.
        Does not return anything; the world will handle the force application over time.
        """
        # Validate strength input
        if strength not in self.STRENGTH_MAP:
            strength = "medium"
            
        base_force = self.STRENGTH_MAP[strength]
        
        # Add a realistic variation to the force magnitude once per push
        actual_force_magnitude = abs(base_force + random.gauss(0, self.force_noise_std))
        
        # Normalize direction vector and calculate components
        dir_magnitude = sum(d**2 for d in direction)**0.5
        if dir_magnitude == 0:
            return # Avoid arbitrary directions
            
        force_vector = [(d / dir_magnitude) * actual_force_magnitude for d in direction]
        
        # Experimental imperfection: tiny initial random variance in position and velocity
        for i in range(len(obj.position)):
            obj.position[i] += random.gauss(0, self.pos_noise_std)
        for i in range(len(obj.velocity)):
            obj.velocity[i] += random.gauss(0, self.vel_noise_std)
        
        # Register the planned push with the world/experiment tracker
        push_event = {
            "object": obj,
            "force_vector": force_vector,
            "remaining_time": duration
        }
        
        # We add this to the world's active experiments list or handle it in a tick abstract
        if obj not in self.world.objects:
            self.world.add_object(obj)
            
        self.world.active_events.append(push_event)
