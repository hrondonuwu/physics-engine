import random
from engine.config import SENSOR_CONFIG, DT

class PositionSensor:
    def __init__(self, obj):
        """
        A sensor that provides real-time noisy position readings.
        Simulates measurement jitter/lag and spatial noise.
        """
        self.obj = obj
        
        # Load configuration for this sensor type
        config = SENSOR_CONFIG.get("position_sensor", {})
        self.noise_std = config.get("noise_std", 0.05)
        self.lag_std = config.get("lag_std", 0.02) # Seconds of lag to simulate jitter
        
    def tick(self):
        """
        Called every timestep by the world.
        Staircase lock removed. Method retained for API compatibility.
        """
        pass

    def read(self):
        """
        Returns a live noisy position reading, incorporating simulated measurement lag via velocity.
        """
        noisy_position = []
        for p, v in zip(self.obj.position, self.obj.velocity):
            # Jitter: simulated lag (time delay error) * current velocity
            lag_error = random.gauss(0, self.lag_std) * v
            # Spatial noise
            spatial_error = random.gauss(0, self.noise_std)
            noisy_position.append(p + lag_error + spatial_error)
            
        return noisy_position
