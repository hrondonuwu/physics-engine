import random

class DropExperiment:
    def __init__(self, world, noise_std=1e-3):
        """
        Initializes the drop experiment within a specific world.
        """
        self.world = world
        self.noise_std = noise_std

    def drop(self, obj, drop_height, initial_x=0.0):
        """
        Releases an object into the world at a specified height.
        The physics engine takes over. This function returns nothing.
        Experimental imperfection is applied to initial conditions.
        """
        # We assume index 1 is Y (height), and index 0 is X
        actual_x = initial_x + random.gauss(0, self.noise_std)
        actual_y = drop_height + random.gauss(0, self.noise_std)
        
        if len(obj.position) > 1:
            obj.position[0] = actual_x
            obj.position[1] = actual_y
        else:
            obj.position[0] = actual_y
            
        # Tiny random variance in initial velocity (v_0 ± epsilon)
        obj.velocity = [random.gauss(0, self.noise_std) for _ in obj.velocity]
        
        # Ensure object is in the world
        if obj not in self.world.objects:
            self.world.add_object(obj)
            
        # Note: The simulation loop must be run separately via world.run()
