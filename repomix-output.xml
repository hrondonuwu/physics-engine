class MeasurePositionExperiment:
    def __init__(self, position_sensor):
        """
        An experiment that acts as an interface to the PositionSensor.
        The AI interacts with this experiment to get position data, keeping them away
        from raw engine objects or internal sensor properties if we lock it down later.
        """
        self.sensor = position_sensor

    def measure(self):
        """
        Requests a reading from the underlying position sensor.
        Returns the noisy position vector, or the stale reading if queried faster than the update rate.
        """
        return self.sensor.read()
