class TimerExperiment:
    def __init__(self, time_sensor):
        """
        A stopwatch-like experiment that utilizes a TimeSensor.
        Allows the AI user to start and stop the timer to measure elapsed simulation time.
        """
        self.sensor = time_sensor
        self.start_reading = 0.0
        self.is_running = False

    def start(self):
        """
        Starts the timer by recording the current noisy time from the sensor.
        Returns nothing to conceal the absolute internal time from the AI.
        """
        self.start_reading = self.sensor.read()
        self.is_running = True

    def stop(self):
        """
        Stops the timer and returns the noisy elapsed time.
        """
        if not self.is_running:
            return 0.0
            
        end_reading = self.sensor.read()
        self.is_running = False
        
        # Calculate elapsed time (could be slightly negative due to high noise or tiny durations)
        # So we clamp it to 0.0 logically
        elapsed = max(0.0, end_reading - self.start_reading)
        return elapsed

    def reset(self):
        """
        Resets the stopwatch.
        """
        self.is_running = False
        self.start_reading = 0.0
