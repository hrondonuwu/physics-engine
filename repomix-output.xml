import random

class Collisions:
    def __init__(self, ground_y=0.0, restitution=0.5, noise_std=0.02):
        """
        Manages collisions for the simulation.
        Phase 1 primarily handles objects colliding with a ground plane.
        """
        self.ground_y = ground_y
        self.restitution = restitution
        self.noise_std = noise_std
        
    def apply(self, objects, old_positions=None):
        """
        Checks for collisions and resolves them by directly modifying velocity.
        Adds slight randomness to simulate real-world imperfect bounces.
        Uses old_positions to perform raycasting against the ground plane.
        """
        for obj in objects:
            # Assuming 2D/3D where Y is the up/down axis (index 1)
            # Or if 1D, index 0. Let's assume index 1 for Y.
            # If 1D, position[0] is height. We'll check length.
            
            y_index = 1 if len(obj.position) > 1 else 0
            
            old_y = obj.position[y_index]
            if old_positions and id(obj) in old_positions:
                old_y = old_positions[id(obj)][y_index]
                
            new_y = obj.position[y_index]
            
            # Raycasting collision check: Did the object cross the ground plane this step, or is it already below?
            if (old_y > self.ground_y and new_y <= self.ground_y) or (new_y <= self.ground_y):
                # Snap to ground to prevent sinking
                obj.position[y_index] = self.ground_y
                
                # Resolve velocity if moving downward
                if obj.velocity[y_index] < 0:
                    bounce_factor = self.restitution + random.gauss(0, self.noise_std)
                    bounce_factor = max(0.0, min(1.0, bounce_factor)) # Clamp between 0 and 1
                    
                    obj.velocity[y_index] = -obj.velocity[y_index] * bounce_factor
                    
                    # Prevent micro-sinking by stopping the object if velocity is negligible
                    if abs(obj.velocity[y_index]) < 0.1:
                        obj.velocity[y_index] = 0.0
